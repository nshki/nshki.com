---
import Logo from "@/components/vector/logo.astro"
---

<nav class="nav">
  <a class="nav__logo" href="/">
    <Logo />
  </a>

  <ul class="nav__items">
    <li class="nav__item">
      <a class="nav__link" href="/living">Living</a>
    </li>

    <li class="nav__item">
      <a class="nav__link" href="/writing">Writing</a>
    </li>
  </ul>
</nav>

<style>
.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24px;
  margin-bottom: 80px;
  font-family: var(--font-mono);

  @media (min-width: 640px) {
    margin-bottom: 160px;
  }
}

.nav__logo {
  @media (prefers-reduced-motion: no-preference) {
    transition: transform 0.2s ease-in-out;

    &:is(:hover, :focus) {
      transform: translate3d(0, -3px, 0);
    }
  }
}

.nav__items {
  display: flex;
  gap: 32px;
  padding: 0;
  margin: 0;
  list-style: none;
}

.nav__link {
  text-transform: uppercase;
  letter-spacing: 1.6px;
  font-size: 0.875rem;
}
</style>
